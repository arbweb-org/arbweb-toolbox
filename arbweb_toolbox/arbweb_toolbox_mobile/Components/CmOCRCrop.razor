@inject IJSRuntime JS

<div style="
            position:absolute; z-index:100; width: 100vw; height:100vh;
            background-color: silver; opacity: 0.9;
            display: flex; justify-content: center; align-items: center;">
    <img src="@(r_src)" id="ocr_img"
         style="position: relative; max-width:100%; max-height:100%" />
</div>

<div style="position:absolute; z-index:200; width:100vw; padding: 45vh 5vw 0vh 5vw">
    <div class="resizable" id="ocr_box"
         style="height: 10vh;
            border-style: dashed;
            border-width: 3px;
            border-color: orangered;
            background-color: rgba(0, 0, 0, 0.1);
            border-radius: 10px;
            touch-action: none;
            box-sizing: border-box;">
    </div>
</div>

<div style="position: fixed; z-index:300; width:100%; bottom:0px; padding:20px">
    <button type="button" class="btn btn-success" style="width:100%"
            @onclick="@v_close">
        OK
    </button>
</div>